# Neon pooled connection string (PgBouncer) — used at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Neon unpooled connection string — used by Prisma for migrations/introspection
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"
# NextAuth / Auth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET=""
# Deployed app URL (set in production if your Auth.js version requires it)
# NEXTAUTH_URL="https://your-app.vercel.app"
